APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

POSTGRES_HOST=localhost
POSTGRES_PORT=5440
POSTGRES_DB=ai_companion
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5440/ai_companion

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

OPENAI_API_KEY=
ASSISTANT_PROVIDER=local
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_TIMEOUT_SECONDS=15
EMBEDDING_PROVIDER=local
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_TIMEOUT_SECONDS=10
VECTOR_BACKEND=json
VECTOR_EMBEDDING_DIMENSIONS=64
MEMORY_RETRIEVAL_TOP_K=6
MEMORY_RETRIEVAL_CANDIDATE_MULTIPLIER=3
MEMORY_CONTEXT_MAX_CHARS=800
MEMORY_WEIGHT_RELEVANCE=0.65
MEMORY_WEIGHT_IMPORTANCE=0.25
MEMORY_WEIGHT_RECENCY=0.10

JWT_SECRET_KEY=change-me-in-production-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
